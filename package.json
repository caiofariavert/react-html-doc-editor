{
  "name": "react-html-doc-editor",
  "version": "0.1.0",
  "description": "Editor de texto WYSIWYG para React com exportação HTML customizada (estilo Django Template)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\""
  },
  "peerDependencies": {
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "react",
    "editor",
    "wysiwyg",
    "html",
    "django-template"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "mammoth": "^1.11.0"
  }
}
